{
  "id": "openclaw-authloop",
  "name": "AuthLoop",
  "description": "Human-in-the-loop authentication for AI agents — hand off OTP, captcha, and password challenges to a human who resolves them remotely",
  "version": "0.1.0",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "apiKey": { "type": "string" },
      "baseUrl": { "type": "string" }
    }
  },
  "uiHints": {
    "apiKey": { "label": "API Key", "sensitive": true, "placeholder": "al_live_..." },
    "baseUrl": { "label": "API Base URL", "placeholder": "https://api.authloop.ai" }
  }
}
