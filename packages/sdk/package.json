{
  "name": "@authloop-ai/sdk",
  "version": "0.2.0",
  "description": "TypeScript SDK for AuthLoop — human-in-the-loop authentication for AI agents",
  "type": "module",
  "license": "MIT",
  "author": "AuthLoop <hello@authloop.ai> (https://authloop.ai)",
  "homepage": "https://github.com/authloop-ai/authloop/tree/main/packages/sdk#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/authloop-ai/authloop.git",
    "directory": "packages/sdk"
  },
  "bugs": {
    "url": "https://github.com/authloop-ai/authloop/issues"
  },
  "keywords": [
    "authloop",
    "authentication",
    "otp",
    "captcha",
    "ai-agents",
    "human-in-the-loop",
    "mcp",
    "sdk"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "check-types": "tsc --noEmit",
    "codegen": "tsx scripts/generate.ts",
    "codegen:local": "AUTHLOOP_OPENAPI_URL=http://localhost:8787/openapi.json tsx scripts/generate.ts",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts"
  },
  "dependencies": {
    "debug": "^4.4.3"
  },
  "devDependencies": {
    "@types/debug": "^4.1.12",
    "openapi-typescript": "^7.8.0",
    "tsx": "^4.19.4",
    "typescript": "5.9.3"
  }
}
