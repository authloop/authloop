{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "@authloop-ai/extension#check-types": {
      "dependsOn": ["@authloop-ai/extension#build"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "codegen": {
      "cache": false
    },
    "codegen:local": {
      "cache": false
    },
    "test": {
      "dependsOn": ["^build"],
      "cache": false
    }
  }
}
